<settings>
  <queries>

    <!-- 
    ============================================================
    Demo Endpoints (SQLite)
    ============================================================
    These endpoints use SQLite and work out of the box with the 
    bundled demo.db database. No external database setup required.
    
    The tutorial (docs/tutorial/) walks through these same 
    patterns using SQL Server syntax. The queries below are the 
    SQLite equivalents.
    ============================================================
    -->


    <!-- Hello World — GET /hello_world or POST /hello_world with {"name":"Alice"} -->
    <hello_world>
      <query><![CDATA[
        SELECT 'hello ' || COALESCE(NULLIF({{name}}, ''), 'world') 
          || '! Time now is ' || datetime('now') AS message_from_db;
      ]]></query>
    </hello_world>


    <!-- Server Time — GET /server_time -->
    <server_time>
      <route>server_time</route>
      <verb>GET</verb>
      <query><![CDATA[
        SELECT datetime('now', 'localtime') AS server_time;
      ]]></query>
    </server_time>


    <!-- Create Contact — POST /contacts {"name":"Alice","phone":"555-0101"} -->
    <create_contact>
      <route>contacts</route>
      <verb>POST</verb>
      <mandatory_parameters>name,phone</mandatory_parameters>
      <success_status_code>201</success_status_code>
      <response_structure>single</response_structure>
      <query><![CDATA[
        INSERT INTO contacts (name, phone)
        VALUES ({{name}}, {{phone}})
        RETURNING id, name, phone, active;
      ]]></query>
    </create_contact>


    <!-- Get Contact by ID — GET /contacts/{{id}} -->
    <get_contact>
      <route>contacts/{{id}}</route>
      <verb>GET</verb>
      <mandatory_parameters>id</mandatory_parameters>
      <response_structure>single</response_structure>
      <query><![CDATA[
        SELECT id, name, phone, active
        FROM contacts
        WHERE id = {{id}};
      ]]></query>
    </get_contact>


    <!-- Search Contacts — GET /contacts?name=alice&take=10&skip=0 -->
    <search_contacts>
      <route>contacts</route>
      <verb>GET</verb>
      <query><![CDATA[
        SELECT id, name, phone, active
        FROM contacts
        WHERE ({{name}} IS NULL OR name LIKE '%' || {{name}} || '%')
          AND ({{phone}} IS NULL OR phone LIKE '%' || {{phone}} || '%')
        ORDER BY name
        LIMIT COALESCE({{take}}, 100)
        OFFSET COALESCE({{skip}}, 0);
      ]]></query>
      <count_query><![CDATA[
        SELECT COUNT(*)
        FROM contacts
        WHERE ({{name}} IS NULL OR name LIKE '%' || {{name}} || '%')
          AND ({{phone}} IS NULL OR phone LIKE '%' || {{phone}} || '%');
      ]]></count_query>
    </search_contacts>


    <!-- Update Contact — PUT /contacts/{{id}} {"name":"Bob","phone":"555-0202"} -->
    <update_contact>
      <route>contacts/{{id}}</route>
      <verb>PUT</verb>
      <mandatory_parameters>id,name,phone</mandatory_parameters>
      <response_structure>single</response_structure>
      <query><![CDATA[
        UPDATE contacts
        SET name = {{name}}, phone = {{phone}}
        WHERE id = {{id}}
        RETURNING id, name, phone, active;
      ]]></query>
    </update_contact>


    <!-- Delete Contact — DELETE /contacts/{{id}} -->
    <delete_contact>
      <route>contacts/{{id}}</route>
      <verb>DELETE</verb>
      <mandatory_parameters>id</mandatory_parameters>
      <response_structure>single</response_structure>
      <query><![CDATA[
        DELETE FROM contacts
        WHERE id = {{id}}
        RETURNING id, name, phone, active;
      ]]></query>
    </delete_contact>


    <!-- Activate/Deactivate — PUT /contacts/{{id}}/activate or /contacts/{{id}}/deactivate -->
    <activate_deactivate_contact>
      <route>contacts/{{id}}/{{status_action}}</route>
      <verb>PUT</verb>
      <mandatory_parameters>id,status_action</mandatory_parameters>
      <response_structure>single</response_structure>
      <query><![CDATA[
        UPDATE contacts
        SET active = CASE WHEN {{status_action}} = 'activate' THEN 1 ELSE 0 END
        WHERE id = {{id}}
        RETURNING id, name, phone, 
          CASE WHEN active = 1 THEN 'active' ELSE 'inactive' END AS status;
      ]]></query>
    </activate_deactivate_contact>


  </queries>
</settings>
